<!-- views/signup.ejs -->

<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrati - SkillBridge</title>
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico">
    <!-- Boxicons -->
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <!-- CSS -->
    <link rel="stylesheet" href="/css/pages/login-signup.css">
    <!-- JS -->
    <script src="/js/auth-logic.js" defer></script>
    <script src="/js/theme-logic.js" defer></script>
</head>

<body>
    <div class="container">
        <div class="left-section">
            <div class="top-bar">
                <a href="/" class="logo">
                    <img src="/img/favicon.ico" alt="Logo" class="logo-img" />
                    <span class="logo-text">SkillBridge</span>
                </a>
            </div>
            <div class="form-container">
                <h1>Crea un account</h1>
                <p class="subtitle">Registrati e inizia subito.</p>
                <form class="signup-form" action="#" method="POST">
                    <div class="input-wrapper">
                        <i class="bx bx-envelope"></i>
                        <input type="email" id="email" name="email" placeholder="Email" required autocomplete="email" />
                    </div>
                    <div class="input-wrapper">
                        <i class="bx bx-at"></i>
                        <input type="text" id="username" name="username" placeholder="Username" required autocomplete="username">
                        <span id="username-tooltip" class="tooltip">
                            L'username può contenere solo lettere, numeri e trattini. Non sono ammessi spazi o caratteri speciali.
                        </span>
                    </div>
                    <div class="input-wrapper password-wrapper">
                        <i class="bx bx-lock"></i>
                        <input type="password" id="password" name="password" placeholder="Password" required />
                        <button type="button" class="toggle-password"><i class="bx bx-show"></i></button>
                    </div>
                    <div class="input-wrapper password-wrapper">
                        <i class="bx bx-lock"></i>
                        <input type="password" id="confirm-password" name="confirm-password" placeholder="Conferma Password" required  />
                        <button type="button" class="toggle-password"><i class="bx bx-show"></i></button>
                    </div>
                    <div class="terms">
                        <input type="checkbox" id="agree-terms" name="agree-terms" required />
                        <label for="agree-terms">
                            Accetto i <a href="#">termini di servizio</a>
                        </label>
                    </div>
                    <% if (error_msg && error_msg.length > 0) { %>
                        <div class="alert alert-danger">
                            <%= error_msg %>
                        </div>
                    <% } %>
                    <% if (error && error.length > 0) { %>
                        <div class="alert alert-danger">
                            <%= error %>
                        </div>
                    <% } %>
                    <% if (success_msg && success_msg.length > 0) { %>
                        <div class="alert alert-success">
                            <%= success_msg %>
                        </div>
                    <% } %>
                    <button type="submit" class="signup-btn">Registrati</button>
                </form>
                <p class="login-link">Hai già un account? <a href="/login">Effettua il login</a></p>
            </div>
        </div>
        <div class="right-section">
            <div class="card-preview">
                <img src="/img/handshake.png" alt="Riddle Card" />
            </div>
            <div class="card-text">
                <h2>Il tuo ponte verso la crescita professionale</h2>
                <p>Attraverso SkillBridge, il tuo potenziale incontra opportunità concrete: un ambiente dinamico dove freelance e aziende collaborano per innovare e crescere.</p>
            </div>
        </div>
    </div>
</body>

</html>