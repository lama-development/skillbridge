<!-- views/login.ejs -->

<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Accedi - SkillBridge</title>
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico">
    <!-- Boxicons -->
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <!-- CSS -->
    <link rel="stylesheet" href="/css/auth.css">
    <!-- JS -->
    <script src="/js/auth.js" defer></script>
</head>

<body>
    <div class="container">
        <div class="left-section">
            <div class="top-bar">
                <a href="/" class="logo">
                    <img src="/img/favicon.ico" alt="Logo" class="logo-img" />
                    <span class="logo-text">SkillBridge</span>
                </a>
            </div>
            <div class="form-container">
                <h1>Accedi</h1>
                <p class="subtitle">Riprendi da dove hai lasciato.</p>
                <form class="signup-form" action="#" method="POST">
                    <div class="input-wrapper">
                        <i class="bx bx-at"></i>
                        <input type="text" name="emailOrUsername" placeholder="Email o Username" required autocomplete="email" />
                    </div>
                    <div class="input-wrapper password-wrapper">
                        <i class="bx bx-lock"></i>
                        <input type="password" id="password" name="password" placeholder="Password" required />
                        <button type="button" class="toggle-password"><i class="bx bx-show"></i></button>
                    </div>
                    <% if (error_msg && error_msg.length > 0) { %>
                        <div class="alert alert-danger">
                            <%= error_msg %>
                        </div>
                    <% } %>
                    <% if (error && error.length > 0) { %>
                        <div class="alert alert-danger">
                            <%= error %>
                        </div>
                    <% } %>
                    <% if (success_msg && success_msg.length > 0) { %>
                        <div class="alert alert-success">
                            <%= success_msg %>
                        </div>
                    <% } %>
                    <button type="submit" class="signup-btn">Accedi</button>
                </form>
                <p class="login-link">Non hai un account? <a href="/signup">Registrati</a></p>
            </div>
        </div>
        <div class="right-section">
            <div class="card-preview">
                <img src="/img/handshake.png" alt="Riddle Card" />
            </div>
            <div class="card-text">
                <h2>Il tuo ponte verso la crescita professionale</h2>
                <p>Attraverso SkillBridge, il tuo potenziale incontra opportunità concrete: un ambiente dinamico dove freelance e aziende collaborano per innovare e crescere.</p>
            </div>
        </div>
    </div>
</body>

</html>